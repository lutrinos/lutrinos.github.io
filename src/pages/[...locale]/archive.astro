---
export const prerender = true;

export const getStaticPaths = async () => getLocaleStaticPaths();

import { getSortedPostsList } from "@utils/post";
import ArchivePanel from "@components/archivePanel.tsx";
import GridLayout from "@layouts/grid.astro";
import BackwardButton from "@components/backwardButton.astro";
import { useLocale } from "@i18n/translation";
import { getLocaleStaticPaths } from "@utils/locale";
import I18nKey from "@i18n/i18nKey";

const sortedPostsList = await getSortedPostsList();

const i18n = useLocale(Astro.currentLocale);

const pageTitle = i18n(I18nKey.archive)
const pageDescription = "A chronological list of all published posts.";

---

<GridLayout title={pageTitle} description={pageDescription}>
    <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full ">
            <BackwardButton currentPath={Astro.url.pathname} />
            <!-- 标题 -->
            <header class="mb-8">
                <h1 class="text-3xl font-bold text-neutral-900 dark:text-neutral-100 mb-3">
                    {pageTitle}
                </h1>
                {pageDescription && (
                    <p class="text-neutral-600 dark:text-neutral-400">
                        {pageDescription}
                    </p>
                )}
            </header>
            <!-- 归档面板 -->
            <ArchivePanel postsCountLabel={I18nKey.postsCount} postCountLabel={i18n(I18nKey.postCount)} sortedPosts={sortedPostsList} client:idle></ArchivePanel>
        </div>
    </div>
</GridLayout>